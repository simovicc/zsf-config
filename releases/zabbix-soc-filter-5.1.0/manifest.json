{
  "manifest_version": 3,
  "name": "Zabbix SOC Filter",
  "version": "5.1.0",
  "description": "Whitelist filter za Zabbix dashboard - prikazuje samo probleme koji se šalju klijentima.",
  "author": "Stefan Simović",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://api.ipify.org/*",
    "https://ipv4.icanhazip.com/*",
    "https://ifconfig.me/*",
    "https://monitor.comtradecloud.com/*",
    "http://172.31.35.31/*",
    "https://*.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://monitor.comtradecloud.com/*",
        "http://172.31.35.31/*"
      ],
      "js": [
        "browser-polyfill.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "notify.mp3",
        "inject.js",
        "dnevnik.html",
        "icons/icon128.png",
        "icons/icon48.png",
        "icons/icon16.png"
      ],
      "matches": [
        "https://monitor.comtradecloud.com/*",
        "http://172.31.35.31/*"
      ]
    }
  ],
  "action": {
    "default_title": "Zabbix SOC Filter",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}